# ─────────────────────────────────────────────────────────────────────────────
# .env.docker — Variables de entorno para Docker Compose
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env.docker
#   2. Rellena los valores reales (especialmente JWT_SECRET_KEY y OPENAI_API_KEY)
#   3. NUNCA subas .env.docker al repositorio (está en .gitignore)
#
# Genera JWT_SECRET_KEY con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambia_esto_root_password
MYSQL_DATABASE=smartbudget_db
MYSQL_USER=sb_user
MYSQL_PASSWORD=cambia_esto_user_password

# ── Backend ────────────────────────────────────────────────────────────────
# IMPORTANTE: el host es "mysql" (nombre del servicio en docker-compose.yml)
DATABASE_URL=mysql+pymysql://sb_user:cambia_esto_user_password@mysql:3306/smartbudget_db

# ── JWT ────────────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_Y_ALEATORIA_DE_64_CARACTERES
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-PON_AQUI_TU_API_KEY_DE_OPENAI
OPENAI_MODEL=gpt-4o

# ── Moneda ─────────────────────────────────────────────────────────────────
MONEDA=PEN
SIMBOLO_MONEDA=S/.

# ── Límites ────────────────────────────────────────────────────────────────
MAX_METAS_ACTIVAS=10
OCR_CONFIANZA_MINIMA=0.6
